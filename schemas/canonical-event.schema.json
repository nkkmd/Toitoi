{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://toitoi.cultivationdata.net/schemas/v1/canonical-event.schema.json",
  "title": "Toitoi Canonical Event",
  "description": "Schema for Toitoi Canonical Event JSONL objects. Repository release v1.0.0 retains schemaVersion 0.1.0 as the stable wire identifier; release and wire-schema versions are independent.",
  "type": "object",
  "required": ["id", "schemaVersion", "type", "createdAt", "body", "provenance"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^tt:evt:[^\\s]+$",
      "description": "Transport-independent canonical event ID. The value is opaque and must use the tt:evt:<opaque-id> form."
    },
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0",
      "description": "Stable Canonical Event wire-schema identifier for the v1.0.0 repository release. It is not the repository release version."
    },
    "type": {
      "type": "string",
      "enum": ["inquiry", "observation", "annotation", "response", "synthesis"],
      "description": "Semantic event type."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 UTC timestamp."
    },
    "body": {
      "type": "object",
      "required": ["text", "language"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "language": {
          "type": "string",
          "pattern": "^[A-Za-z]{2,8}(-[A-Za-z0-9]{1,8})*$",
          "description": "BCP47-style language tag (e.g. ja, en, ja-JP)."
        }
      },
      "additionalProperties": false
    },
    "contexts": {
      "type": "object",
      "description": "Abstracted locality/context metadata. Custom keys are allowed.",
      "additionalProperties": true
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "#/definitions/relation" }
    },
    "phase": {
      "type": "string",
      "enum": ["beginner", "intermediate", "expert"]
    },
    "trigger": {
      "type": "object",
      "required": ["category", "value"],
      "properties": {
        "category": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "dsl": {
      "type": "object",
      "required": ["models"],
      "properties": {
        "models": {
          "type": "array",
          "items": { "$ref": "#/definitions/dslModel" }
        }
      },
      "additionalProperties": false
    },
    "lineage": {
      "type": "array",
      "items": { "$ref": "#/definitions/lineageEdge" }
    },
    "provenance": {
      "type": "object",
      "required": ["sources"],
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/provenanceSource" }
        }
      },
      "additionalProperties": false
    },
    "identityClaims": {
      "type": "array",
      "items": { "$ref": "#/definitions/identityClaim" },
      "description": "Optional third-party verifiable identity claims attached to the canonical event."
    },
    "rawRef": {
      "type": "object",
      "required": ["protocol", "sourceId"],
      "properties": {
        "protocol": {
          "type": "string",
          "minLength": 1,
          "description": "Protocol name for the raw payload reference, such as nostr, atproto, or activitypub."
        },
        "sourceId": {
          "type": "string",
          "minLength": 1,
          "description": "Protocol-specific identifier for the raw payload."
        },
        "relay": {
          "type": "string",
          "minLength": 1,
          "description": "Optional transport endpoint or retrieval hint for the raw payload."
        },
        "storage": {
          "type": "string",
          "minLength": 1,
          "description": "Optional storage class or backend name that holds the raw payload."
        },
        "storageId": {
          "type": "string",
          "minLength": 1,
          "description": "Optional storage-local identifier or path for the raw payload."
        },
        "payloadHash": {
          "type": "string",
          "minLength": 1,
          "description": "Optional content hash for integrity checks on the raw payload."
        }
      },
      "additionalProperties": false
    },
    "labels": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Optional topical labels used for transport projections."
    },
    "meta": {
      "type": "object",
      "description": "Optional non-semantic implementation metadata.",
      "additionalProperties": true
    }
  },
  "definitions": {
    "relation": {
      "type": "object",
      "required": ["source", "target"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "dslVariable": {
      "type": "object",
      "required": ["name", "role"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "role": {
          "type": "string",
          "enum": ["independent", "dependent", "mediator", "moderator"]
        }
      },
      "additionalProperties": false
    },
    "dslModel": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "variables": {
          "type": "array",
          "items": { "$ref": "#/definitions/dslVariable" }
        },
        "relations": {
          "type": "array",
          "items": { "$ref": "#/definitions/relation" }
        },
        "meta": {
          "type": "object",
          "description": "Optional model-level implementation metadata.",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "provenanceSource": {
      "type": "object",
      "required": ["protocol", "sourceId"],
      "properties": {
        "protocol": {
          "type": "string",
          "minLength": 1,
          "description": "Source protocol name, such as nostr or atproto."
        },
        "sourceId": {
          "type": "string",
          "minLength": 1,
          "description": "Protocol-specific source identifier."
        },
        "uri": {
          "type": "string",
          "minLength": 1,
          "description": "Optional ATProto URI or equivalent transport locator."
        },
        "cid": {
          "type": "string",
          "minLength": 1,
          "description": "Optional content identifier for ATProto payloads."
        },
        "did": {
          "type": "string",
          "minLength": 1,
          "description": "Optional decentralized identifier for ATProto records."
        },
        "collection": {
          "type": "string",
          "minLength": 1,
          "description": "Optional ATProto collection name."
        },
        "rkey": {
          "type": "string",
          "minLength": 1,
          "description": "Optional ATProto record key."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Optional source timestamp when available."
        },
        "relay": {
          "type": "string",
          "minLength": 1,
          "description": "Optional transport endpoint for the source."
        },
        "kind": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional source kind or event type when applicable."
        }
      },
      "additionalProperties": false
    },
    "identityClaim": {
      "type": "object",
      "required": ["schemaVersion", "claimType", "ruleVersion", "identityKey", "canonicalId", "issuer", "issuedAt", "verification"],
      "properties": {
        "schemaVersion": { "type": "string", "const": "0.1.0" },
        "claimType": { "type": "string", "const": "identity" },
        "ruleVersion": { "type": "string", "minLength": 1 },
        "identityKey": { "type": "string", "pattern": "^tt:key:[^\\s]+$" },
        "canonicalId": { "type": "string", "pattern": "^tt:evt:[^\\s]+$" },
        "issuer": {
          "type": "object",
          "required": ["protocol", "sourceId"],
          "properties": {
            "protocol": { "type": "string", "minLength": 1 },
            "sourceId": { "type": "string", "minLength": 1 },
            "signerId": { "type": "string", "minLength": 1 },
            "publicKey": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "issuedAt": { "type": "string", "format": "date-time" },
        "verification": {
          "type": "object",
          "required": ["method", "payloadHash"],
          "properties": {
            "method": { "type": "string", "minLength": 1 },
            "payloadHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            "signature": { "type": "string", "minLength": 1 },
            "keyId": { "type": "string", "minLength": 1 },
            "publicKey": { "type": "string", "minLength": 1 },
            "status": { "type": "string", "enum": ["pending", "verified", "rejected"] }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "lineageEdge": {
      "type": "object",
      "required": ["type", "target"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1,
          "description": "Normative derivation values are derived_from, translated_from, observed_alongside, contrasts_with, synthesizes, reframes, annotates, and revises. Other values require the documented vocabulary change process."
        },
        "target": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
