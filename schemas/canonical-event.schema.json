{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://toitoi.dev/schemas/canonical-event.schema.json",
  "title": "Toitoi Canonical Event",
  "description": "Schema for Toitoi Canonical Event JSONL objects (spec v0.3.0).",
  "type": "object",

  "required": [
    "id",
    "schemaVersion",
    "type",
    "createdAt",
    "body",
    "provenance"
  ],

  "properties": {
    "id": {
      "type": "string",
      "pattern": "^tt:(evt|obj):[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "Transport-independent canonical event ID. Recommended format: tt:evt:<ULID>; tt:obj:<ULID> remains accepted for legacy data."
    },

    "schemaVersion": {
      "type": "string",
      "const": "0.3.0",
      "description": "Canonical schema version."
    },

    "type": {
      "type": "string",
      "enum": ["inquiry", "observation", "annotation", "response", "synthesis"],
      "description": "Semantic event type."
    },

    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 UTC timestamp."
    },

    "body": {
      "type": "object",
      "required": ["text", "language"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "pattern": "^[A-Za-z]{2,8}(-[A-Za-z0-9]{1,8})*$",
          "description": "BCP47-style language tag (e.g. ja, en, ja-JP)."
        }
      },
      "additionalProperties": false
    },

    "contexts": {
      "type": "object",
      "description": "Abstracted locality/context metadata. Custom keys are allowed.",
      "additionalProperties": true
    },

    "relationships": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/relation"
      }
    },

    "phase": {
      "type": "string",
      "enum": ["beginner", "intermediate", "expert"]
    },

    "trigger": {
      "type": "object",
      "required": ["category", "value"],
      "properties": {
        "category": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },

    "dsl": {
      "type": "object",
      "required": ["models"],
      "properties": {
        "models": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/dslModel"
          }
        }
      },
      "additionalProperties": false
    },

    "lineage": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/lineageEdge"
      }
    },

    "provenance": {
      "type": "object",
      "required": ["sources"],
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/provenanceSource"
          }
        }
      },
      "additionalProperties": false
    },

    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Optional topical labels used for transport projections."
    },

    "meta": {
      "type": "object",
      "description": "Optional non-semantic implementation metadata.",
      "additionalProperties": true
    }
  },

  "definitions": {
    "relation": {
      "type": "object",
      "required": ["source", "target"],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },

    "dslVariable": {
      "type": "object",
      "required": ["name", "role"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": ["independent", "dependent", "mediator", "moderator"]
        }
      },
      "additionalProperties": false
    },

    "dslModel": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "variables": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/dslVariable"
          }
        },
        "relations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/relation"
          }
        },
        "meta": {
          "type": "object",
          "description": "Optional model-level implementation metadata.",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },

    "provenanceSource": {
      "type": "object",
      "required": ["protocol", "sourceId"],
      "properties": {
        "protocol": {
          "type": "string",
          "minLength": 1,
          "description": "Source protocol name, such as nostr or atproto."
        },
        "sourceId": {
          "type": "string",
          "minLength": 1,
          "description": "Protocol-specific source identifier."
        },
        "relay": {
          "type": "string",
          "minLength": 1,
          "description": "Optional transport endpoint for the source."
        },
        "kind": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional source kind or event type when applicable."
        }
      },
      "additionalProperties": false
    },

    "lineageEdge": {
      "type": "object",
      "required": ["type", "target"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1,
          "description": "Recommended values: derived_from, synthesis, annotates, revises."
        },
        "target": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },

  "additionalProperties": true
}
