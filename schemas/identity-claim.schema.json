{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://toitoi.cultivationdata.net/schemas/v1/identity-claim.schema.json",
  "title": "Toitoi Identity Claim",
  "description": "Schema for third-party verifiable identity claims that bind an identity key to a canonical id.",
  "type": "object",
  "required": [
    "schemaVersion",
    "claimType",
    "ruleVersion",
    "identityKey",
    "canonicalId",
    "issuer",
    "issuedAt",
    "verification"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "claimType": {
      "type": "string",
      "const": "identity"
    },
    "ruleVersion": {
      "type": "string",
      "minLength": 1
    },
    "identityKey": {
      "type": "string",
      "pattern": "^tt:key:[^\\s]+$"
    },
    "canonicalId": {
      "type": "string",
      "pattern": "^tt:evt:[^\\s]+$"
    },
    "issuer": {
      "type": "object",
      "required": [
        "protocol",
        "sourceId"
      ],
      "properties": {
        "protocol": {
          "type": "string",
          "minLength": 1
        },
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "signerId": {
          "type": "string",
          "minLength": 1
        },
        "publicKey": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "verification": {
      "type": "object",
      "required": [
        "method",
        "payloadHash"
      ],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "payloadHash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "signature": {
          "type": "string",
          "minLength": 1
        },
        "keyId": {
          "type": "string",
          "minLength": 1
        },
        "publicKey": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "verified",
            "rejected"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
