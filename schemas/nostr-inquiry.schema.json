{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://toitoi.cultivationdata.net/schemas/v1/nostr-inquiry.schema.json",
  "title": "Toitoi Nostr Inquiry Event",
  "description": "Schema for Toitoi Nostr inquiry transport events (kind 1042).",
  "type": "object",
  "required": [
    "kind",
    "id",
    "pubkey",
    "created_at",
    "content",
    "tags",
    "sig"
  ],
  "properties": {
    "kind": {
      "type": "integer",
      "const": 1042,
      "description": "Nostr event kind for Toitoi inquiries."
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Nostr event id."
    },
    "pubkey": {
      "type": "string",
      "minLength": 1,
      "description": "Nostr public key."
    },
    "created_at": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp in seconds."
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "description": "Natural language body of the inquiry."
    },
    "tags": {
      "type": "array",
      "description": "Nostr tag list. Each tag is a string array.",
      "items": {
        "oneOf": [
          {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": [
              { "const": "t" },
              {
                "type": "string",
                "minLength": 1
              }
            ],
            "additionalItems": false
          },
          {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": [
              { "const": "context" },
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ],
            "additionalItems": false
          },
          {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": [
              { "const": "relationship" },
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ],
            "additionalItems": false
          },
          {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": [
              { "const": "phase" },
              {
                "type": "string",
                "enum": ["beginner", "intermediate", "expert"]
              }
            ],
            "additionalItems": false
          },
          {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": [
              { "const": "trigger" },
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ],
            "additionalItems": false
          },
          {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": [
              { "const": "e" },
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ],
            "additionalItems": false
          },
          {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": [
              { "const": "dsl:model" },
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ],
            "additionalItems": false
          },
          {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": [
              { "const": "dsl:var" },
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "enum": ["independent", "dependent", "mediator", "moderator"]
              }
            ],
            "additionalItems": false
          },
          {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": [
              { "const": "dsl:rel" },
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ],
            "additionalItems": false
          },
          {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": [
              { "const": "dsl:meta" },
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ],
            "additionalItems": false
          },
          {
            "type": "array",
            "minItems": 1,
            "items": [
              {
                "type": "string",
                "not": {
                  "enum": [
                    "t",
                    "context",
                    "relationship",
                    "phase",
                    "trigger",
                    "e",
                    "dsl:model",
                    "dsl:var",
                    "dsl:rel",
                    "dsl:meta"
                  ]
                }
              }
            ],
            "additionalItems": {
              "type": "string"
            }
          }
        ]
      }
    },
    "sig": {
      "type": "string",
      "minLength": 1,
      "description": "Nostr signature."
    },
    "relay": {
      "type": "string",
      "minLength": 1,
      "description": "Optional relay hint used by ingest and provenance tooling."
    }
  },
  "additionalProperties": true
}
